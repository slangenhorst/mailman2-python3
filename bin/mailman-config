"""Show basic statistics about, and build options for this
installation of Mailman. Requires python 2."""
from __future__ import print_function

print("""Configuration and build information for Mailman\n""")

print('Mailman version: %s' % '2.1.39')
print('Build Date:      %s' % 'Wed Jun  5 14:35:53 UTC 2024')
print('')
print('prefix:          %s' % '/var/lib/mailman')
print('var_prefix:      %s' % '/var/lib/mailman')
print('mailman_user:    %s' % 'list')
print('mailman_group:   %s' % 'list')
print('mail_group:      %s' % 'daemon')
print('cgi_group:       %s' % 'www-data')
print('')


print('configure_opts: "%s"' % '--prefix=/var/lib/mailman --with-username=list --with-groupname=list --with-mail-gid=daemon --with-cgi-gid=www-data --without-permcheck --with-mailhost=localhost --with-urlhost=localhost')

